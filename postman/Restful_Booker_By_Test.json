                  "    url: pm.environment.get('base_url') + '/booking',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            firstname: 'Original',",
                  "            lastname: 'Name',",
                  "            totalprice: 111,",
                  "            depositpaid: true,",
                  "            bookingdates: { checkin: '2026-06-10', checkout: '2026-06-13' },",
                  "            additionalneeds: 'Breakfast'",
                  "        })",
                  "    }",
                  "}, function (err, res) {",
                  "    const body = res.json();",
                  "    pm.environment.set('booking_id', body.bookingid);",
                  "});",
                  "",
                  "pm.sendRequest({",
                  "    url: pm.environment.get('base_url') + '/auth',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: {",
