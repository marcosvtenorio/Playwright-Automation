        {
          "name": "BK07 - valid: should retrieve booking by ID after creation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Pre-request: Create a booking to retrieve",
                  "pm.sendRequest({",
                  "    url: pm.environment.get('base_url') + '/booking',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            firstname: 'Retrieve',",
                  "            lastname: 'Test',",
                  "            totalprice: 150,",
                  "            depositpaid: true,",
                  "            bookingdates: { checkin: '2026-06-10', checkout: '2026-06-13' }",
                  "        })",
                  "    }",
                  "}, function (err, res) {",
                  "    const body = res.json();",
                  "    pm.environment.set('booking_id', body.bookingid);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('BK07 — Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('BK07 — Response has correct booking properties', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('firstname');",
                  "    pm.expect(body).to.have.property('lastname');",
                  "    pm.expect(body).to.have.property('totalprice');",
                  "    pm.expect(body).to.have.property('depositpaid');",
                  "    pm.expect(body).to.have.property('bookingdates');",
                  "    pm.expect(body.firstname).to.eql('Retrieve');",
                  "    pm.expect(body.lastname).to.eql('Test');",
                  "});",
                  "",
                  "pm.test('BK07 — Date format is YYYY-MM-DD', function () {",
                  "    const body = pm.response.json();",
                  "    const dateRegex = /^\\d{4}-\\d{2}-\\d{2}$/;",
                  "    pm.expect(body.bookingdates.checkin).to.match(dateRegex);",
                  "    pm.expect(body.bookingdates.checkout).to.match(dateRegex);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
