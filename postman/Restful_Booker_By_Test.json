              "listen": "test",
              "script": {
                "exec": [
                  "// BUG-001: Returns 200 instead of 201",
                  "pm.test('BK01 — Status is 200 (BUG-001: should be 201)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('BK01 — Response has bookingid and booking details', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('bookingid');",
                  "    pm.expect(body.bookingid).to.be.greaterThan(0);",
                  "    pm.expect(body.booking.firstname).to.eql('John');",
                  "    pm.expect(body.booking.lastname).to.eql('Doe');",
                  "    pm.expect(body.booking.totalprice).to.eql(111);",
                  "    pm.expect(body.booking.depositpaid).to.eql(true);",
                  "    pm.environment.set('booking_id', body.bookingid);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
