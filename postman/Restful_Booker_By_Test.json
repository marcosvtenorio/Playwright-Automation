  "item": [
    {
      "name": "Authentication Tests (AU)",
      "description": "Tests: AU01-AU02\nSpec: tests/api/auth.spec.ts",
      "item": [
        {
          "name": "AU01 - valid: should authenticate with valid admin credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('AU01 — Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('AU01 — Response contains valid token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body.token).to.be.a('string');",
                  "    pm.expect(body.token.length).to.be.greaterThan(0);",
                  "    pm.environment.set('token', body.token);",
                  "});",
                  "",
                  "pm.test('AU01 — Schema: token is string', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(typeof body.token).to.eql('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": ["{{base_url}}"],
              "path": ["auth"]
            },
            "description": "AU01: Authenticate with valid admin credentials.\nExpected: 200 with {token: string}."
          }
        },
        {
          "name": "AU02 - invalid: should reject invalid credentials (BUG-007)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// BUG-007: API returns 200 instead of 401",
                  "pm.test('AU02 — Status code is 200 (BUG-007: should be 401)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('AU02 — Response contains reason: Bad credentials', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('reason');",
                  "    pm.expect(body.reason).to.eql('Bad credentials');",
                  "});",
                  "",
                  "pm.test('AU02 — No token in response', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.token).to.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"invalid\",\n  \"password\": \"invalid\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth",
              "host": ["{{base_url}}"],
              "path": ["auth"]
            },
            "description": "AU02: Attempt auth with invalid credentials.\nBUG-007: Returns 200 with {reason} instead of 401."
          }
        }
      ]
